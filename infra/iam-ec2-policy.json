{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AnyCharDynamoDB",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:BatchWriteItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:*:*:table/AnyChar",
        "arn:aws:dynamodb:*:*:table/AnyChar/index/GSI1"
      ]
    },
    {
      "Sid": "AnyCharS3Images",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::anychar-images-*/*"
    },
    {
      "Sid": "AnyCharS3List",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::anychar-images-*"
    }
  ]
}
